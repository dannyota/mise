# AlloyDB
ALLOYDB_HOST=localhost
ALLOYDB_PORT=5432
ALLOYDB_USER=mise
ALLOYDB_PASSWORD=mise-dev
ALLOYDB_DATABASE=mise

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=mise-ingest

# Vertex AI seam (real | fake)
VERTEX=fake

# Vertex (Mode A — real, optional for dev)
GCP_PROJECT=
GCP_REGION=us-central1

# Doc AI Layout Parser (VERTEX=real; location "us" or "eu")
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=

# Raw-artifact blob store: GCS_BUCKET set → GCS (ADC), else local BLOB_DIR
# (the compose worker mounts the raw-data volume at /data/raw instead)
BLOB_DIR=./data/raw
GCS_BUCKET=

# Serving
SERVING_PORT=8080
MISE_DB_ROLE=mise_public

# Reasoning
REASONING_PORT=3001

# Web
VITE_SERVING_URL=http://localhost:8080
VITE_REASONING_URL=http://localhost:3001
