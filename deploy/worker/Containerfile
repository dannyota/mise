# mise worker image — Temporal workers for the ingest pipeline and detectors
# (cmd/worker). No inbound port: this process only dials out to Temporal + AlloyDB.
#
# Build (from repo root):
#   podman build -t mise-worker -f deploy/worker/Containerfile .

FROM docker.io/library/golang:1.26 AS build

ENV CGO_ENABLED=0 \
    GOFLAGS=-trimpath

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN go build -ldflags="-s -w" -o /worker ./cmd/worker

# distroless static: ca-certificates + a nonroot (uid 65532) user, no shell or
# package manager. Works because the binary is CGO-free and fully static.
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=build /worker /worker

USER nonroot:nonroot
ENTRYPOINT ["/worker"]
