# mise web image — Vue 3.5 SPA (apps/web), served as static files behind nginx.
#
# Build (from repo root):
#   podman build -t mise-web -f deploy/web/Containerfile .

FROM docker.io/library/node:24-slim AS build
WORKDIR /app

# Every workspace member's manifest must be present before `install
# --frozen-lockfile` — pnpm resolves the lockfile against the full workspace
# member set declared by pnpm-workspace.yaml, even members this image never builds.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/package.json
COPY apps/reasoning/package.json apps/reasoning/package.json
COPY packages/contract/package.json packages/contract/package.json
RUN corepack enable && pnpm install --frozen-lockfile

COPY apps/web/ apps/web/
COPY packages/contract/ packages/contract/
RUN pnpm --filter @mise/web build

# Vite bundles vue/vue-router into dist/ at build time — the runtime image
# needs only the static output, never node_modules.
FROM docker.io/library/nginx:alpine
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
