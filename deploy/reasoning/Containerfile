# mise reasoning image — Node 24 + Hono reasoning endpoint (apps/reasoning).
#
# Build (from repo root):
#   podman build -t mise-reasoning -f deploy/reasoning/Containerfile .
#
# pnpm workspaces store every dependency once under the root node_modules/.pnpm
# store and symlink into each package's own node_modules/. The runtime stage
# therefore keeps the monorepo-relative layout (root node_modules + the
# package's own node_modules) intact rather than flattening dist/ to the image
# root — flattening breaks the relative symlinks pnpm relies on.

FROM docker.io/library/node:24-slim AS build
WORKDIR /app

# Every workspace member's manifest must be present before `install
# --frozen-lockfile` — pnpm resolves the lockfile against the full workspace
# member set declared by pnpm-workspace.yaml, even members this image never builds.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/reasoning/package.json apps/reasoning/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/contract/package.json packages/contract/package.json
RUN corepack enable && pnpm install --frozen-lockfile

COPY apps/reasoning/ apps/reasoning/
COPY packages/contract/ packages/contract/
RUN pnpm --filter @mise/reasoning build

FROM docker.io/library/node:24-slim
WORKDIR /app

COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/packages/contract ./packages/contract
COPY --from=build /app/apps/reasoning ./apps/reasoning

USER node
WORKDIR /app/apps/reasoning
CMD ["node", "dist/index.js"]
