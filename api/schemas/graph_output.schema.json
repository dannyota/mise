{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mise.dannyota.dev/schemas/graph_output.schema.json",
  "title": "mise MCP graph tool output",
  "description": "Output of mise's MCP `graph` tool (API-CONTRACT.md §2) — a node's tier-scoped edges and the control chain walked from it. Mirrors pkg/mcp.GraphOutput.",
  "type": "object",
  "additionalProperties": false,
  "required": ["nodes", "edges", "chain"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/graph_node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/graph_edge" }
    },
    "chain": {
      "type": "array",
      "items": { "$ref": "#/$defs/graph_hop" }
    }
  },
  "$defs": {
    "graph_node": {
      "type": "object",
      "description": "One graph node reference — a corpus/document, optionally narrowed to a section. Mirrors pkg/mcp.GraphNode.",
      "additionalProperties": false,
      "required": ["corpus_id", "document_id"],
      "properties": {
        "corpus_id": { "type": "string" },
        "document_id": { "type": "string" },
        "section_id": { "type": "string" }
      }
    },
    "graph_edge": {
      "type": "object",
      "description": "One graph.relation_edge row, carrying its best evidence's confidence/grounding_score. Mirrors pkg/mcp.GraphEdge.",
      "additionalProperties": false,
      "required": [
        "id",
        "from_corpus_id",
        "from_document_id",
        "to_ref_id",
        "to_corpus_id",
        "edge_type",
        "direction",
        "promoted",
        "access_tier",
        "confidence",
        "grounding_score",
        "created_at"
      ],
      "properties": {
        "id": { "type": "string" },
        "from_corpus_id": { "type": "string" },
        "from_document_id": { "type": "string" },
        "from_section_id": { "type": "string" },
        "to_ref_id": { "type": "string" },
        "to_corpus_id": { "type": "string" },
        "edge_type": { "type": "string" },
        "direction": { "type": "string" },
        "promoted": { "type": "boolean" },
        "access_tier": { "type": "string" },
        "confidence": { "type": "number" },
        "grounding_score": { "type": "number" },
        "created_at": { "type": "string" }
      }
    },
    "graph_hop": {
      "type": "object",
      "description": "One control-chain hop — the wire form of store.Hop. Mirrors pkg/mcp.GraphHop.",
      "additionalProperties": false,
      "required": [
        "corpus_id",
        "document_id",
        "edge_type",
        "citation",
        "text",
        "promoted",
        "confidence",
        "grounding_score"
      ],
      "properties": {
        "corpus_id": { "type": "string" },
        "document_id": { "type": "string" },
        "section_id": { "type": "string" },
        "edge_type": { "type": "string" },
        "citation": { "type": "string" },
        "text": { "type": "string" },
        "promoted": { "type": "boolean" },
        "confidence": { "type": "number" },
        "grounding_score": { "type": "number" }
      }
    }
  }
}
