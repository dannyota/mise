{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mise.dannyota.dev/schemas/search_output.schema.json",
  "title": "mise MCP search tool output",
  "description": "Output of mise's MCP `search` tool (API-CONTRACT.md §2) — ranked evidence sections. Mirrors pkg/mcp.SearchOutput.",
  "type": "object",
  "additionalProperties": false,
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "items": { "$ref": "#/$defs/section_hit" }
    }
  },
  "$defs": {
    "section_hit": {
      "type": "object",
      "description": "One ranked section result. Mirrors pkg/mcp.SectionHit.",
      "additionalProperties": false,
      "required": [
        "corpus_id",
        "document_id",
        "section_id",
        "doc_number",
        "title",
        "citation_path",
        "heading_path",
        "text",
        "validity_status",
        "score",
        "source_url"
      ],
      "properties": {
        "corpus_id": { "type": "string" },
        "document_id": { "type": "string" },
        "section_id": { "type": "string" },
        "doc_number": { "type": "string" },
        "title": { "type": "string" },
        "citation_path": { "type": "string" },
        "heading_path": { "type": "string" },
        "text": { "type": "string" },
        "validity_status": { "type": "string" },
        "score": { "type": "number" },
        "source_url": { "type": "string" }
      }
    }
  }
}
