{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mise.dannyota.dev/schemas/review_output.schema.json",
  "title": "mise review queue output",
  "description": "Output of GET /reviews — paginated list of unpromoted edges pending human review.",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/review_item" }
    },
    "next_cursor": { "type": "string" }
  },
  "$defs": {
    "review_item": {
      "type": "object",
      "description": "One unpromoted edge with its best evidence confidence/grounding.",
      "additionalProperties": false,
      "required": ["edge", "confidence", "grounding_score"],
      "properties": {
        "edge": { "$ref": "#/$defs/edge" },
        "confidence": { "type": "number" },
        "grounding_score": { "type": "number" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to_ref_id",
        "to_corpus_id",
        "edge_type",
        "direction",
        "promoted",
        "access_tier",
        "created_at",
        "evidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "from": { "$ref": "#/$defs/node_ref" },
        "to_ref_id": { "type": "string" },
        "to_corpus_id": { "type": "string" },
        "edge_type": { "type": "string" },
        "direction": { "type": "string" },
        "promoted": { "type": "boolean" },
        "access_tier": { "type": "string" },
        "created_at": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "node_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus_id", "document_id"],
      "properties": {
        "corpus_id": { "type": "string" },
        "document_id": { "type": "string" },
        "section_id": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "evidence_kind",
        "confidence",
        "grounding_score",
        "created_at"
      ],
      "properties": {
        "id": { "type": "string" },
        "evidence_kind": { "type": "string" },
        "confidence": { "type": "number" },
        "grounding_score": { "type": "number" },
        "rationale": { "type": "string" },
        "quoted_from_span": { "type": "string" },
        "quoted_to_span": { "type": "string" },
        "model": { "type": "string" },
        "prompt_hash": { "type": "string" },
        "created_by": { "type": "string" },
        "promoted_by": { "type": "string" },
        "run_id": { "type": "string" },
        "promoted_at": { "type": "string" },
        "created_at": { "type": "string" }
      }
    }
  }
}
