{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mise.dannyota.dev/schemas/finding_output.schema.json",
  "title": "mise finding output",
  "description": "Output of GET /findings — paginated list of cross-corpus detector findings (gap, conflict, stale).",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "next_cursor": { "type": "string" }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "description": "One graph.finding row — a cross-corpus detector result.",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "severity",
        "status",
        "node_refs",
        "evidence",
        "access_tier",
        "detected_at",
        "dedup_key"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "severity": { "type": "string" },
        "status": { "type": "string" },
        "node_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/node_ref" }
        },
        "evidence": {},
        "access_tier": { "type": "string" },
        "detected_at": { "type": "string" },
        "dedup_key": { "type": "string" }
      }
    },
    "node_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus_id", "document_id"],
      "properties": {
        "corpus_id": { "type": "string" },
        "document_id": { "type": "string" },
        "section_id": { "type": "string" }
      }
    }
  }
}
