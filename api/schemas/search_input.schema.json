{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mise.dannyota.dev/schemas/search_input.schema.json",
  "title": "mise MCP search tool input",
  "description": "Input for mise's MCP `search` tool (API-CONTRACT.md §2). Mirrors pkg/mcp.SearchInput.",
  "type": "object",
  "additionalProperties": false,
  "required": ["query"],
  "properties": {
    "query": { "type": "string", "minLength": 1 },
    "corpora": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Corpus IDs to search; omit for all registered corpora."
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "description": "Max results; default 10."
    },
    "as_of_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "YYYY-MM-DD; omit for current."
    },
    "in_force_only": {
      "type": "boolean",
      "description": "Default true; false includes repealed/superseded."
    }
  }
}
